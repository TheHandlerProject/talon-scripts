<?xml version="1.0" encoding="UTF-8"?>
<openbox_config>
  <theme>
    <name>Clearlooks</name>
    <titleLayout>NLIMC</titleLayout>
    <keepBorder>yes</keepBorder>
    <animateIconify>no</animateIconify>
    <font place="ActiveWindow">
      <name>Sans</name>
      <size>9</size>
      <weight>bold</weight>
    </font>
  </theme>
  <desktops>
    <number>2</number>
    <firstdesk>1</firstdesk>
    <names>
      <name>Main</name>
      <name>Demo</name>
    </names>
  </desktops>
  <keyboard>
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="W-t">
      <action name="Execute">
        <command>xterm</command>
      </action>
    </keybind>
    <keybind key="C-Right">
      <action name="GoToDesktop">
        <to>next</to>
        <wrap>yes</wrap>
      </action>
    </keybind>
    <keybind key="C-Left">
      <action name="GoToDesktop">
        <to>previous</to>
        <wrap>yes</wrap>
      </action>
    </keybind>
  </keyboard>
  <mouse>
    <dragThreshold>1</dragThreshold>
    <doubleClickTime>200</doubleClickTime>
    <screenEdgeWarpTime>0</screenEdgeWarpTime>
  </mouse>
  <applications>
    <application name="xterm">
      <maximized>yes</maximized>
      <decor>no</decor>
    </application>
  </applications>
</openbox_config>
